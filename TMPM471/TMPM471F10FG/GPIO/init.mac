execUserPreload()
{
	__message "Executing execUserPreload() function\n";
	__hwReset(0);
	_Disable_WDT();
}

execUserReset()
{
	__message "Executing execUserReset() function\n";
	_Disable_WDT();
}

_Disable_WDT()
{
	__message "-----  Disable WDT  -----";
	__writeMemory32(0x00000000, 0x400A0604, "Memory"); // SIWD0EN
	__writeMemory32(0x000000B1, 0x400A0608, "Memory"); // SIWD0CR
}