execUserPreload()
{
	__message "Executing execUserPreload() function\n";
	_Disable_WDT();
}

execUserReset()
{
	__message "Executing execUserReset() function\n";
	_Disable_WDT();
}

_Disable_WDT()
{
	//Disable WDT
	__message "-----  Disable WDT  -----";
	__writeMemory32(0x00,0x400F2000,"Memory");
	__writeMemory32(0xB1,0x400F2004,"Memory");
}